{
  "name": "we-subscribe-to-posts",
  "version": "1.2.1",
  "description": "WordPress plugin for post update subscriptions.",
  "scripts": {
    "pot": "node scripts/update-pot.js",
    "make-pot": "npm run pot",
    "i18n:json": "node scripts/make-json.js",
    "json": "npm run i18n:json",
    "sync:version": "node scripts/sync-version.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "build:mjml-browser": "node scripts/build-mjml-browser.js",
    "build:mjml-starters": "node scripts/compile-mjml-starters.js",
    "build:mjml": "npm run build:mjml-browser && npm run build:mjml-starters"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "mjml": "^4.15.3",
    "mjml-browser": "^4.15.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gbyat/we-subscribe-to-posts.git"
  },
  "keywords": [
    "wordpress",
    "plugin",
    "i18n"
  ],
  "author": "webentwicklerin, Gabriele Laesser",
  "license": "GPL-2.0-or-later",
  "type": "commonjs"
}
